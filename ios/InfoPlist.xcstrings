    "NSMicrophoneUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "يحتاج InstaSOS إلى الوصول إلى الميكروفون لتسجيل الفيديوهات مع الصوت." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS benötigt Zugriff auf Ihr Mikrofon, um Videos mit Ton aufzunehmen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS needs access to your microphone to record videos with audio." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS necesita acceso al micrófono para grabar vídeos con audio." } },
        "fil" : { "stringUnit" : { "state" : "translated", "value" : "Kailangan ng InstaSOS ng access sa iyong microphone para mag-record ang mga video na may audio." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS a besoin d'accéder à votre microphone pour enregistrer des vidéos avec audio." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "ऑडियो के साथ वीडियो रिकॉर्ड करने के लिए InstaSOS को आपके माइक्रोफ़ोन तक पहुंच की आवश्यकता है।" } },
        "ht" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS bezwen aksè a mikwofòn ou an pou anrejistre videyo ak odyo." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "音声付きのビデオを録画するには、InstaSOSにマイクへのアクセス権限が必要です。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS는 오디오와 함께 동영상을 녹화하기 위해 마이크 접근 권한이 필요합니다." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS требуется доступ к микрофону для записи видео со звуком." } },
        "sw" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS inahitaji ufikiaji wa maikrofoni yako ili kurekodi video zenye sauti." } },
        "uk" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS потрібен доступ до мікрофона для запису відео зі звуком." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS 需要访问您的麦克风，以便录制带音频的视频。" } }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "يحتاج InstaSOS إلى الوصول إلى مكتبة الصور لديك لحفظ الصور/الفيديوهات." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS benötigt Zugriff auf Ihre Fotomediathek, um Fotos/Videos zu speichern." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS needs access to your photo library to save photos/videos." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS necesita acceso a tu galería para guardar fotos y vídeos." } },
