    "NSCameraUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "يحتاج InstaSOS إلى الوصول إلى كاميرتك لمشاركة الصور/الفيديوهات مع جهات اتصال الطوارئ لديك." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS benötigt Zugriff auf Ihre Kamera, um Fotos/Videos mit Ihren Notfallkontakten zu teilen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS needs access to your camera to share photos/videos with your emergency contacts." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS necesita acceso a la cámara para compartir fotos y vídeos con tus contactos de emergencia." } },
        "fil" : { "stringUnit" : { "state" : "translated", "value" : "Kailangan ng InstaSOS ng access sa iyong camera upang maibahagi ang mga larawan/video sa iyong mga emergency contact." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS a besoin d'accéder à votre appareil photo pour partager des photos/vidéos avec vos contacts d'urgence." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS को आपके आपातकालीन संपर्कों के साथ फ़ोटो/वीडियो साझा करने के लिए आपके कैमरे तक पहुंच की आवश्यकता है।" } },
        "ht" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS bezwen aksè a kamera a pou pataje foto/videyo avèk kontak ijans ou yo." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOSが緊急連絡先と写真やビデオを共有するには、カメラへのアクセスが必要です。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS는 비상 연락처와 사진/동영상을 공유하기 위해 카메라 접근 권한이 필요합니다." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS требуется доступ к камере, чтобы делиться фото и видео с вашими экстренными контактами." } },
        "sw" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS inahitaji ufikiaji wa kamera yako ili kushiriki picha/video na unaowasiliana nao wakati wa dharura." } },
        "uk" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS потрібен доступ до вашої камери, щоб ділитися фото/відео з вашими екстренними контактами." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS 需要访问您的相机，以便将照片/视频分享给紧急联系人。" } }
      }
    },
    "NSContactsUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "يحتاج InstaSOS إلى حفظ جهات اتصال الطوارئ لديك." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS muss Ihre Notfallkontakte speichern können." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS needs to be able to save your emergency contacts." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS necesita poder guardar tus contactos de emergencia." } },
        "fil" : { "stringUnit" : { "state" : "translated", "value" : "Kailangan ng permiso ng InstaSOS para ma-save ang iyong mga emergency contact." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS doit pouvoir enregistrer vos contacts d'urgence." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS को आपके आपातकालीन संपर्कों को सहेजने में सक्षम होने की आवश्यकता है।" } },
        "ht" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS bezwen kapab anrejistre kontak ijans ou yo." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOSが緊急連絡先を保存できるようにする必要があります。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS는 비상 연락처를 저장할 수 있어야 합니다." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS должен иметь возможность сохранять ваши экстренные контакты." } },
        "sw" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS inahitaji kuweza kuhifadhi unaowasiliana nao wakati wa dharura." } },
        "uk" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS має мати можливість зберігати ваші контакти для екстрених випадків." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS 需要保存您的紧急联系人信息。" } }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "يحتاج InstaSOS إلى الوصول إلى موقعك لمشاركته مع جهات اتصال الطوارئ لديك." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS benötigt Zugriff auf Ihren Standort, um ihn mit Ihren Notfallkontakten zu teilen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS needs access to your location to share it with your emergency contacts." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS necesita acceso a tu ubicación para compartirla con tus contactos de emergencia." } },
        "fil" : { "stringUnit" : { "state" : "translated", "value" : "Kailangan ng InstaSOS ng access sa iyong lokasyon upang maibahagi ito sa iyong mga emergency contact." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS a besoin d'accéder à votre localisation pour la partager avec vos contacts d'urgence." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS को आपके स्थान को आपके आपातकालीन संपर्कों के साथ साझा करने के लिए उस तक पहुंच की आवश्यकता है।" } },
        "ht" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS bezwen aksè a pozisyon ou pou pataje yo avèk kontak ijans ou yo." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOSが緊急連絡先と現在地を共有するには、位置情報へのアクセスが必要です。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS는 비상 연락처와 위치를 공유하기 위해 위치 정보 접근 권한이 필요합니다." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS требуется доступ к вашему местоположению, чтобы делиться им с вашими экстренными контактами." } },
        "sw" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS inahitaji ufikiaji wa eneo lako ili kulishiriki na unaowasiliana nao wakati wa dharura." } },
        "uk" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS потрібен доступ до вашого місцезнаходження, щоб ділитися ним з вашими екстренними контактами." } },
        "zh" : { "stringUnit" : { "state" : "translated", "value" : "InstaSOS 需要访问您的位置，以便将位置信息分享给紧急联系人。" } }
      }
    },
